  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FP=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // .tool_input.path // .tool_input.pattern // \"\"'); if echo \"$FP\" | grep -qE '(^|/)\\.claude(/|$)' && ! echo \"$FP\" | grep -qE '(^|/)\\.claude/worktrees/'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Accessing .claude/ — confirm this is intentional.\"}}'; fi",
            "statusMessage": "Checking .claude/ directory access"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FP=$(cat | jq -r '.tool_input.file_path // \"\"'); if echo \"$FP\" | grep -qE '(\\.env[^/]*$|/secrets/)'; then echo '{\"decision\":\"block\",\"reason\":\"Protected file: requires human review.\"}'; exit 0; fi; if echo \"$FP\" | grep -qE '/migrations/'; then ROOT=$(cd \"${CLAUDE_PROJECT_DIR:-.}\" && git rev-parse --show-toplevel 2>/dev/null); if [ -n \"$ROOT\" ]; then REL=\"${FP#$ROOT/}\"; if git -C \"$ROOT\" cat-file -e \"main:$REL\" 2>/dev/null; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Applied migration (exists on main): confirm edit.\"}}'; fi; fi; fi",
            "statusMessage": "Checking protected files & migrations"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_supabase_supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "SQL=$(cat | jq -r '.tool_input.sql // .tool_input.query // \"\"' | tr '[:lower:]' '[:upper:]'); for KW in INSERT UPDATE DELETE DROP ALTER TRUNCATE CREATE GRANT REVOKE COMMENT; do if echo \"$SQL\" | grep -qw \"$KW\"; then echo '{\"decision\":\"block\",\"reason\":\"Write SQL blocked. execute_sql is restricted to read-only (SELECT/SHOW/EXPLAIN/DESCRIBE).\"}'; exit 0; fi; done",
            "statusMessage": "Checking SQL is read-only"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // \"\"'); for PAT in 'rm -r /' 'DROP TABLE' 'DROP DATABASE' 'chmod 777' 'curl.*\\|.*sh' 'wget.*\\|.*sh'; do if echo \"$CMD\" | grep -qiE \"$PAT\"; then jq -n --arg p \"$PAT\" '{\"decision\":\"block\",\"reason\":(\"Blocked dangerous command pattern: \"+$p)}'; exit 0; fi; done; if echo \"$CMD\" | grep -qiE 'rm -rf'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"rm -rf detected — confirm before running\"}}'; exit 0; fi",
            "statusMessage": "Checking for dangerous patterns"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // \"\"'); if echo \"$CMD\" | grep -qE '^git commit'; then [ -f \"${CLAUDE_PROJECT_DIR:-.}/package.json\" ] || exit 0; cd \"${CLAUDE_PROJECT_DIR:-.}\"; SECRETS=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null | grep -iE '(AKIA[0-9A-Z]{16}|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|password\\s*[:=]\\s*\\S+|secret_?key\\s*[:=]\\s*\\S+|-----BEGIN (RSA |EC |DSA )?PRIVATE KEY)' || true); if [ -n \"$SECRETS\" ]; then echo '{\"decision\":\"block\",\"reason\":\"Potential secrets detected in staged changes.\"}'; exit 0; fi; npx tsc --noEmit 2>&1 | tail -10; TSC=$?; npx eslint . --max-warnings 0 2>&1 | tail -10; LINT=$?; if [ $TSC -ne 0 ] || [ $LINT -ne 0 ]; then jq -n --arg r \"Pre-commit gate failed: tsc($TSC) lint($LINT). Fix before committing.\" '{\"decision\":\"block\",\"reason\":$r}'; exit 0; fi; fi",
            "timeout": 60,
            "statusMessage": "Running pre-commit checks"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // \"\"'); if echo \"$CMD\" | grep -qE '^git ((-C [^ ]+ )?push)'; then cd \"${CLAUDE_PROJECT_DIR:-.}\"; pnpm quality 2>&1 | tail -30; QUAL=$?; if [ $QUAL -ne 0 ]; then jq -n --arg r \"Pre-push quality gate failed. Fix issues before pushing.\" '{\"decision\":\"block\",\"reason\":$r}'; exit 0; fi; fi",
            "timeout": 1800000,
            "statusMessage": "Running quality checks before push"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/read-once/hook.sh",
            "statusMessage": "Tracking read-once files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path'); npx prettier --write \"$FILE\" 2>/dev/null; echo '{\"suppressOutput\": true}'",
            "timeout": 15,
            "statusMessage": "Auto-formatting with prettier"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"${CLAUDE_PROJECT_DIR:-.}/package.json\" ] || exit 0; grep -q vitest \"${CLAUDE_PROJECT_DIR:-.}/package.json\" || exit 0; cd \"${CLAUDE_PROJECT_DIR:-.}\" && npx vitest run --reporter=verbose 2>&1 | tail -40; TEST=$?; if [ $TEST -ne 0 ]; then echo 'Stop gate: test suite failing. Fix all issues before completing.'; exit 1; fi",
            "timeout": 120,
            "statusMessage": "Running test suite"
          }
        ]
      }
    ]
  },
